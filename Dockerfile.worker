FROM node:22-alpine

# Install pnpm via corepack
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate

WORKDIR /app

# 1. Copy workspace structure for dependency caching
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY tsconfig.base.json ./

# Copy all package.json files (workspace packages + modules)
# web is needed for pnpm lockfile resolution even though we don't run it
COPY apps/web/package.json apps/web/
COPY apps/worker/package.json apps/worker/
COPY packages/db/package.json packages/db/
COPY packages/llm/package.json packages/llm/
COPY packages/module-sdk/package.json packages/module-sdk/
COPY modules/summary/package.json modules/summary/
COPY modules/key-points/package.json modules/key-points/
COPY modules/vocab-flashcard/package.json modules/vocab-flashcard/
COPY modules/quiz/package.json modules/quiz/
COPY modules/mindmap/package.json modules/mindmap/

# 2. Install dependencies (cached unless package.json changes)
RUN pnpm install --frozen-lockfile

# 3. Copy source code
COPY packages/ packages/
COPY modules/ modules/
COPY apps/worker/ apps/worker/

# 4. Start worker
CMD ["pnpm", "--filter", "@dinodigest/worker", "start"]
